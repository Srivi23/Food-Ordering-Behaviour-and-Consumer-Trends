<style>
  /* ============================================================
     BASE
     ============================================================ */
  html { scroll-behavior: smooth; }
  body { background-color: #15130F; }

  ::selection { background: #E8543E; color: #15130F; }

  /* Custom thin scrollbar, kept subtle so it doesn't fight the theme */
  ::-webkit-scrollbar { width: 10px; }
  ::-webkit-scrollbar-track { background: #15130F; }
  ::-webkit-scrollbar-thumb { background: #272119; border-radius: 999px; border: 2px solid #15130F; }
  ::-webkit-scrollbar-thumb:hover { background: #3a3226; }

  /* ============================================================
     SIGNATURE MOTIF: the order-ticket / receipt system
     Used for: hero receipt, dataset stub-cards, story filmstrip,
     recommendations callout. This is the throughline that ties
     "food ordering" + "data" together visually.
     ============================================================ */

  /* Dashed perforation line, like a tear-off ticket edge */
  .perforated {
    background-image: radial-gradient(circle, #15130F 2.5px, transparent 2.6px);
    background-size: 14px 14px;
    background-repeat: repeat-x;
    background-position: left center;
    height: 6px;
  }

  /* Jagged torn-paper bottom edge for the receipt card */
  .torn-edge {
    clip-path: polygon(
      0% 0%, 100% 0%, 100% 96%,
      96% 100%, 92% 95%, 88% 100%, 84% 95%, 80% 100%,
      76% 95%, 72% 100%, 68% 95%, 64% 100%, 60% 95%,
      56% 100%, 52% 95%, 48% 100%, 44% 95%, 40% 100%,
      36% 95%, 32% 100%, 28% 95%, 24% 100%, 20% 95%,
      16% 100%, 12% 95%, 8% 100%, 4% 95%, 0% 100%
    );
  }

  /* Barcode divider used in the footer — pure CSS, no image asset */
  .barcode {
    height: 40px;
    background-image:
      repeating-linear-gradient(90deg, #F5F1E8 0px, #F5F1E8 2px, transparent 2px, transparent 5px),
      repeating-linear-gradient(90deg, #F5F1E8 0px, #F5F1E8 1px, transparent 1px, transparent 9px);
    opacity: 0.85;
  }

  /* ============================================================
     SCROLL REVEAL
     Elements start slightly lower + transparent, then ease in
     when they cross into the viewport (see JS IntersectionObserver)
     ============================================================ */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.in-view { opacity: 1; transform: translateY(0); }

  /* Stagger helper — pairs with inline style delays set in JS/markup */
  .reveal.delay-1 { transition-delay: 0.08s; }
  .reveal.delay-2 { transition-delay: 0.16s; }
  .reveal.delay-3 { transition-delay: 0.24s; }
  .reveal.delay-4 { transition-delay: 0.32s; }

  /* ============================================================
     RECEIPT PRINT-IN ANIMATION (hero)
     Each <li> is hidden, then revealed line-by-line to mimic a
     thermal printer producing an order ticket.
     ============================================================ */
  .receipt-line {
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .receipt-line.printed { opacity: 1; transform: translateY(0); }

  /* Subtle printer flicker on the "LIVE" dot */
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  .pulse-dot { animation: pulse-dot 1.6s ease-in-out infinite; }

  /* ============================================================
     CARD HOVER — data cards feel tactile / analytical
     ============================================================ */
  .data-card {
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.35s ease, box-shadow 0.35s ease;
  }
  .data-card:hover {
    transform: translateY(-6px) scale(1.015);
    box-shadow: 0 20px 40px -20px rgba(232, 84, 62, 0.35);
  }

  .ticket-stub:hover { transform: translateY(-4px) rotate(-1deg); }
  .ticket-stub:nth-child(even):hover { transform: translateY(-4px) rotate(1deg); }
  .ticket-stub { transition: transform 0.3s ease, border-color 0.3s ease; }

  /* Nav link underline-on-hover, drawn with a pseudo element */
  .nav-link { position: relative; }
  .nav-link::after {
    content: '';
    position: absolute; left: 0; bottom: -4px;
    width: 0; height: 1.5px;
    background: #E8543E;
    transition: width 0.25s ease;
  }
  .nav-link:hover::after { width: 100%; }

  /* Story filmstrip dots */
  .story-dot { transition: background-color 0.25s ease, transform 0.25s ease; }
  .story-dot.active { background-color: #E8543E; transform: scale(1.3); }

  /* Focus states kept visible for accessibility/keyboard nav */
  a:focus-visible, button:focus-visible {
    outline: 2px solid #E8543E;
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    .reveal, .receipt-line, .data-card, .ticket-stub, .pulse-dot { transition: none !important; animation: none !important; opacity: 1 !important; transform: none !important; }
  }
</style>
